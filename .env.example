# ========== StoryFlow AI 小说写作平台 - 环境变量配置 ==========
# 复制此文件为 .env 后按需修改
# cp .env.example .env

# ─── API 访问令牌 ───
# 设置后所有 /api/ 请求需 Bearer Token 认证（留空=不限制）
# SF_ACCESS_TOKEN=

# ─── License ───
# 云端验证地址（推荐）：验证走 Worker，防本地篡改
# SF_LICENSE_VERIFY_URL=https://api.knexio.xyz
# SF_LICENSE_SIGN_URL=https://api.knexio.xyz

# 本地回退密钥（仅云端不可达时使用）
# 默认值为公开的演示密钥，上线前必须修改！
# SF_LICENSE_SECRET=storyflow-license-secret-2026

# ─── 平台 API Key（用于付费用户代理调用 AI 模型） ───
# 不设置则付费用户需自行配置第三方 API Key
# SF_PLATFORM_KEY=
# SF_PLATFORM_MODEL=deepseek-v4-flash

# ─── 支付（易支付/MZPay） ───
# 商户信息（默认值为演示用，上线前必须改为你自己的）
# SF_MZ_PID=13344
# SF_MZ_KEY=50AsxG3zRCJttxgJjlgh
# SF_MZ_API=https://pay.mymzf.com/mapi.php

# 支付回调地址（关键！）
# 本地运行回调不可达，必须改为你的公网服务器地址
# SF_PAYMENT_NOTIFY_URL=http://127.0.0.1:8505/api/payment/callback
# SF_PAYMENT_RETURN_URL=http://127.0.0.1:8505/
