# ========== StoryFlow AI 小说写作平台 - 环境变量配置 ==========
# 本项目为自部署项目，所有配置均为可选

# 可选：API 访问令牌（设置后所有 /api/ 请求需要 Bearer Token 认证）
# 默认空=不限制。建议仅在需要暴露到公网时设置
# SF_ACCESS_TOKEN=your-secure-token-here

# 可选：平台 API Key（用于付费用户的 AI 模型代理）
# 不设置则用户需要自行配置第三方 API Key
# SF_PLATFORM_KEY=your-platform-api-key

# 可选：平台 API 使用的模型（默认 deepseek-v4-flash）
# SF_PLATFORM_MODEL=deepseek-v4-flash
